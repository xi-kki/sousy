# xAI Grok API — get a key at https://console.x.ai
# Copy this file to ".env" and paste your key. The .env file is gitignored and the
# key is only ever read server-side (server/index.js) — it never reaches the browser.
GROK_API_KEY=xai-your-key-here

# Model + endpoint (optional overrides)
GROK_MODEL=grok-4
GROK_BASE_URL=https://api.x.ai/v1

# Port the proxy server listens on (Vite proxies /api here)
PORT=3001
