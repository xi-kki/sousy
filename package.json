{
  "name": "sousy",
  "version": "1.0.0",
  "type": "module",
  "description": "🔪 Sousy — AI sous-chef voice assistant for commercial kitchen inventory",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json"
  },
  "dependencies": {
    "@xyflow/svelte": "^0.1.37",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "groq-sdk": "^0.3.1"
  },
  "devDependencies": {
    "@lucide/svelte": "^0.487.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tsconfig/svelte": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "bits-ui": "^1.3.19",
    "clsx": "^2.1.1",
    "concurrently": "^9.0.1",
    "dagre": "^0.8.5",
    "embla-carousel-svelte": "^8.6.0",
    "formsnap": "^2.0.1",
    "mode-watcher": "^0.5.1",
    "paneforge": "1.0.0-next.5",
    "svelte": "^5.20.2",
    "svelte-check": "^4.1.4",
    "svelte-sonner": "^0.3.28",
    "sveltekit-superforms": "^2.24.1",
    "tailwind-merge": "^3.2.0",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.7.2",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^6.2.0",
    "zod": "^3.24.2"
  }
}
