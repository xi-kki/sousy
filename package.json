{
  "name": "sousy-voice-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "🔪 Sousy — hands-free voice AI agent for commercial kitchen inventory. Browser Web Speech + Groq LLM. Eclipse design system.",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit && tsc --project server/jsconfig.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.4",
    "@react-three/drei": "^8.20.2",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@theatre/core": "^0.7.2",
    "@theatre/r3f": "^0.7.2",
    "@theatre/studio": "^0.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shader-park-core": "^0.2.8",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
}
